{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.json",
  "name": "io.github.stoneip/esim-mcp-server",
  "description": "Search and buy travel data eSIMs (ALT eSIM / altesim.com) from AI agents. 200+ destinations, USD, instant QR delivery.",
  "version": "0.2.0",
  "repository": {
    "url": "https://github.com/Stoneip/esim-mcp-server",
    "source": "github"
  },
  "websiteUrl": "https://altesim.com/en/ai",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "esim-mcp-server",
      "version": "0.2.0",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "ALTESIM_API_BASE",
          "description": "Override the API base (default https://altesim.com)",
          "isRequired": false,
          "default": "https://altesim.com"
        }
      ]
    }
  ]
}
